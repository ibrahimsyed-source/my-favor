// My Favor — data model. Mirrors src/types in the app.
//
// Provider is SQLite for zero-setup local dev. To go to production, change
// `provider` to "postgresql" and point DATABASE_URL at your Postgres instance —
// the models below are written to be portable (no SQLite-only features; arrays
// are stored as JSON strings, enums are validated in app code via Zod).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Users / profiles
// ---------------------------------------------------------------------------
model User {
  id           String  @id @default(uuid())
  firstName    String
  lastName     String
  email        String  @unique
  phone        String  @unique
  passwordHash String
  avatar       String?
  bio          String?
  city         String?
  state        String?
  zip          String?
  homeAddress  String?
  role         String  @default("member") // "member" | "pal"
  status       String  @default("online") // "online" | "invisible" | "offline"
  verified     Boolean @default(false)

  // Trust & safety: a pal must pass identity/background vetting before they can
  // accept favors (they enter members' homes). Gated server-side, not client trust.
  palVerified   Boolean   @default(false)
  palVerifiedAt DateTime?
  palVetStatus  String    @default("none") // "none" | "pending" | "approved" | "rejected"

  // Moderation: a suspended/banned account cannot log in or use the API.
  suspended       Boolean   @default(false)
  suspendedReason String?

  // Compliance: proof-of-consent + eligibility captured at signup (TCPA/terms + 18+).
  termsAcceptedAt DateTime?
  termsVersion    String?
  dateOfBirth     DateTime?
  ageAffirmed     Boolean   @default(false)

  // Stripe: customer id (member, for charges) + Connect account id (pal, for payouts)
  stripeCustomerId String?
  stripeConnectId  String?

  // Pal stats
  rating          Float @default(0)
  totalFavors     Int   @default(0)
  yearsActive     Int   @default(0)
  reliability     Int   @default(0)
  positiveReviews Int   @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  favorsAsMember Favor[]        @relation("MemberFavors")
  favorsAsPal    Favor[]        @relation("PalFavors")
  cards          PaymentMethod[]
  transactions   Transaction[]
  sentMessages   Message[]
  notifications  Notification[]
  refreshTokens  RefreshToken[]
  otpCodes       OtpCode[]
  reportsMade    Report[]       @relation("Reporter")
  reportsAgainst Report[]       @relation("Reported")
  blocksMade     Block[]        @relation("Blocker")
  blocksAgainst  Block[]        @relation("Blocked")
  threadsAsA     Thread[]       @relation("ThreadUserA")
  threadsAsB     Thread[]       @relation("ThreadUserB")
  favorEvents    FavorEvent[]
}

// ---------------------------------------------------------------------------
// Favors (the core marketplace object)
// ---------------------------------------------------------------------------
model Favor {
  id          String  @id @default(uuid())
  memberId    String
  palId       String?
  tier        String  // "tiny" | "small" | "big" | "huge" | "custom" | "negotiate"
  price       Float
  description String
  images      String  @default("[]") // JSON-encoded string[] (portable across SQLite/PG)

  locationLat     Float
  locationLng     Float
  locationAddress String

  status      String   @default("requested")
  scheduledFor DateTime?
  hours       Int?

  // Money (server-computed; never trusted from the client)
  serviceFee     Float
  transactionFee Float
  total          Float
  tip            Float?

  // Review (member rates pal)
  rating    Int?
  feedback  String?
  etaWindow String?
  // Reverse review (pal rates member)
  palRating   Int?
  palFeedback String?

  // Stripe charge for this favor (set when payments are live)
  stripePaymentIntentId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  member User         @relation("MemberFavors", fields: [memberId], references: [id], onDelete: Cascade)
  pal    User?        @relation("PalFavors", fields: [palId], references: [id], onDelete: SetNull)
  events FavorEvent[]

  @@index([memberId])
  @@index([palId])
  @@index([status])
}

// Status timeline / audit trail for a favor — drives the tracking UI.
model FavorEvent {
  id       String   @id @default(uuid())
  favorId  String
  status   String
  actorId  String?
  at       DateTime @default(now())

  favor Favor @relation(fields: [favorId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([favorId])
}

// ---------------------------------------------------------------------------
// Payments
// ---------------------------------------------------------------------------
model PaymentMethod {
  id          String  @id @default(uuid())
  userId      String
  stripePmId  String? // Stripe PaymentMethod id when real Stripe is wired
  brand       String
  last4       String
  expMonth    Int
  expYear     Int
  isDefault   Boolean @default(false)
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Transaction {
  id          String   @id @default(uuid())
  userId      String
  favorId     String
  title       String
  amount      Float
  status      String // TransactionStatus (completed | processing | paid_out | incomplete | cancelled | ...)
  kind        String // "payment" | "earning"
  payoutBatch String? // groups earnings claimed by one cash-out, for safe accounting
  date        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([payoutBatch]) // cashout reads/writes + payout.failed webhook filter by batch
  @@index([favorId]) // payment_intent webhooks look up the txn by favor
  @@index([userId, kind]) // ledger list endpoints split payments vs earnings per user
}

// ---------------------------------------------------------------------------
// Messaging
// ---------------------------------------------------------------------------
model Thread {
  id          String   @id @default(uuid())
  userAId     String
  userBId     String
  lastMessage String   @default("")
  unreadForA  Int      @default(0)
  unreadForB  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userA    User      @relation("ThreadUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB    User      @relation("ThreadUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages Message[]

  @@unique([userAId, userBId])
  @@index([userAId])
  @@index([userBId])
}

model Message {
  id        String   @id @default(uuid())
  threadId  String
  senderId  String
  text      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User   @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([threadId])
  // Serves the newest-first paginated thread read (where threadId + orderBy createdAt desc + cursor).
  @@index([threadId, createdAt])
}

// ---------------------------------------------------------------------------
// Notifications
// ---------------------------------------------------------------------------
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // "match" | "cancellation" | "no_pal" | "arrived" | "general"
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Trust & safety
// ---------------------------------------------------------------------------
model Report {
  id             String   @id @default(uuid())
  reporterId     String
  reportedUserId String
  favorId        String?
  reason         String?
  status         String   @default("open") // "open" | "reviewing" | "actioned" | "dismissed"
  createdAt      DateTime @default(now())

  reporter User @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User @relation("Reported", fields: [reportedUserId], references: [id], onDelete: Cascade)

  @@index([reportedUserId])
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  blocker User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@index([blockerId])
}

// ---------------------------------------------------------------------------
// Auth: refresh tokens (hashed, revocable) + OTP codes (hashed, single-use)
// ---------------------------------------------------------------------------
model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique // sha-256 of the opaque refresh token; raw token never stored
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id          String   @id @default(uuid())
  userId      String?
  destination String   // email or phone the code was sent to
  codeHash    String   // bcrypt hash of the 6-digit code; raw code never stored
  purpose     String   // "signup" | "login" | "reset"
  expiresAt   DateTime
  consumed    Boolean  @default(false)
  attempts    Int      @default(0)
  lockedUntil DateTime? // set when the per-code attempt cap is hit; resend refused until it passes
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([destination])
}

// Stripe webhook idempotency — persists handled event ids so a redelivery is a
// no-op across restarts/instances (the previous in-memory dedupe was lost on
// every deploy, risking double-processing of payment/payout events).
model ProcessedWebhookEvent {
  id        String   @id // Stripe event id (evt_...)
  type      String
  createdAt DateTime @default(now())
}
