# ---------------------------------------------------------------------------
# My Favor backend configuration. Copy to `.env` and fill in real values.
# NEVER commit the real .env — it holds secrets. .env is gitignored.
# ---------------------------------------------------------------------------

# Runtime
NODE_ENV=development
PORT=4000

# Comma-separated list of allowed CORS origins (the app / web preview).
# In production set this to your real domains only — never "*".
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Database. SQLite for local dev; switch the provider in prisma/schema.prisma
# to "postgresql" and point this at your Postgres URL for production.
DATABASE_URL="file:./prisma/dev.db"

# JWT secrets — MUST be long, random, and secret. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# The server refuses to boot in production if these are missing or too weak.
JWT_ACCESS_SECRET=replace-with-a-64+char-random-string
JWT_REFRESH_SECRET=replace-with-a-different-64+char-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30

# OTP (phone/email verification). In development the code is returned in the
# API response so you can test without a real SMS provider. In production wire
# Twilio/email and set OTP_DEV_RETURN=false so codes are never exposed.
OTP_DEV_RETURN=true
OTP_TTL_MINUTES=10

# Stripe (payments). Leave blank to run in mock mode (no real charges).
# When set, real Stripe calls are used and the webhook signature is verified.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
