{
  "root": true,
  "env": {
    "node": true,
    "es2022": true
  },
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": ["eslint:recommended"],
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "prisma/migrations/"
  ],
  "rules": {
    "no-undef": "off",
    "no-unused-vars": "warn",
    "no-empty": "warn",
    "no-console": "off",
    "no-constant-condition": "warn"
  }
}
