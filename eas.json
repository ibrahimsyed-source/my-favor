{
  "cli": {
    "version": ">= 12.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:4000"
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://my-favor-api.onrender.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "_comment_EXPO_PUBLIC_GOOGLE_MAPS_KEY": "MUST be set before store release; left empty intentionally.",
        "EXPO_PUBLIC_API_URL": "https://my-favor-api.onrender.com",
        "EXPO_PUBLIC_GOOGLE_MAPS_KEY": ""
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "REPLACE_WITH_YOUR_APPLE_ID_EMAIL",
        "ascAppId": "REPLACE_WITH_YOUR_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "REPLACE_WITH_YOUR_APPLE_TEAM_ID"
      },
      "android": {
        "serviceAccountKeyPath": "./path-to-google-play-service-account.json",
        "track": "internal"
      }
    }
  }
}
